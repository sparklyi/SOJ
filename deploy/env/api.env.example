SOJ_ENV=docker
SOJ_HTTP_ADDR=:8080
SOJ_WORKER_HEALTH_ADDR=:8081
SOJ_DATABASE_DSN=postgres://soj:soj@postgres:5432/soj?sslmode=disable
SOJ_REDIS_ADDR=redis:6379
SOJ_REDIS_STREAM=soj:judge:tasks
SOJ_REDIS_GROUP=judge-workers
SOJ_STORAGE_ENDPOINT=http://minio:9000
SOJ_STORAGE_BUCKET=soj
SOJ_STORAGE_REGION=us-east-1
SOJ_STORAGE_ACCESS_KEY=minioadmin
SOJ_STORAGE_SECRET_KEY=minioadmin
SOJ_STORAGE_PATH_STYLE=true
SOJ_JWT_SECRET=local-dev-secret-change-me
SOJ_JUDGE_ENDPOINT=fake://accepted
SOJ_JUDGE_TIMEOUT=30s
