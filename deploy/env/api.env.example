SOJ_ENV=docker
SOJ_HTTP_ADDR=:8080
SOJ_WORKER_HEALTH_ADDR=:8081
SOJ_DATABASE_DSN=postgres://soj:soj@postgres:5432/soj?sslmode=disable
SOJ_REDIS_ADDR=redis:6379
SOJ_REDIS_STREAM=soj:judge:tasks
SOJ_REDIS_GROUP=judge-workers
SOJ_STORAGE_ENDPOINT=http://minio:9000
SOJ_STORAGE_BUCKET=soj
SOJ_STORAGE_REGION=us-east-1
SOJ_STORAGE_ACCESS_KEY=minioadmin
SOJ_STORAGE_SECRET_KEY=minioadmin
SOJ_STORAGE_PATH_STYLE=true
SOJ_JWT_SECRET=local-dev-secret-change-me
SOJ_JUDGE_ENDPOINT=agent://local
SOJ_JUDGE_SANDBOX_BACKEND=fake
SOJ_JUDGE_REQUEST_STREAM=soj:judge:tasks
SOJ_JUDGE_AGENT_GROUP=judge-agents
SOJ_JUDGE_RESULT_STREAM=soj:judge:results
SOJ_JUDGE_RESULT_GROUP=judge-result-consumers
SOJ_JUDGE_PARALLELISM=1
SOJ_JUDGE_LANGUAGE_SLOTS=
SOJ_JUDGE_MAX_BATCH=16
SOJ_DOCKER_RUNNER_RUNTIME=
SOJ_DOCKER_RUNNER_IMAGE_GO=ghcr.io/sparklyi/soj-runner-go:main
SOJ_DOCKER_RUNNER_IMAGE_CPP17=ghcr.io/sparklyi/soj-runner-cpp17:main
SOJ_DOCKER_RUNNER_WORKDIR=/tmp/soj-runner-work
SOJ_JUDGE_TIMEOUT=30s
SOJ_TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_SERVICE_NAME=
OTEL_RESOURCE_ATTRIBUTES=
